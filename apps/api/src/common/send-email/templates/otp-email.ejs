<!doctype html>
<html>

<head>
    <meta charset="utf-8" />
    <title>Zipher OTP</title>
</head>

<body style="font-family: Arial, Helvetica, sans-serif; color:#111;">
    <div style="max-width:600px;margin:0 auto;padding:24px;border:1px solid #eee;">
        <h2 style="color:#1f8a70;">Hello <%= senderName %>,</h2>
        <p>Your One-Time Password (OTP) for Zipher is:</p>
        <p style="font-size:28px;letter-spacing:2px;font-weight:700;margin:16px 0;">
            <%= otp %>
        </p>
        <p>This code will expire in <%= expiresInMinutes || 10 %> minutes.</p>
        <hr />
        <p style="font-size:12px;color:#666;">If you didn't request this, ignore this email.</p>
        <p style="font-size:12px;color:#666;">— Zipher.lk</p>
    </div>
</body>

</html>